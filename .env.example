# Required for live multimodal extraction through Nebius Token Factory.
# Server-only. Never prefix this key with VITE_.
NEBIUS_API_KEY=

# Optional Nebius model override.
NEBIUS_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct

# Required to activate Supabase accounts, full cross-device persistence, and live share links.
# Copy both browser-visible values from the Supabase project Connect panel.
# Security depends on Supabase Auth plus the RLS policies in supabase/schema.sql.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional until live OpenEMR integration is enabled. The adapter remains in synthetic mode
# when these are absent. Register Vital Passport as a confidential SMART app using
# client_secret_post plus Authorization Code with PKCE. The secret stays server-side in Vercel.
OPENEMR_BASE_URL=https://your-openemr.example.com/openemr
OPENEMR_SITE=default
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_REDIRECT_URI=https://vitalpassport.com/openemr/callback
# OPENEMR_SCOPES=openid offline_access api:fhir user/Patient.rs user/DocumentReference.crs user/Observation.crs user/Condition.crs user/AllergyIntolerance.crs user/Provenance.crs
