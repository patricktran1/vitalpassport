# Required for live multimodal extraction through Nebius Token Factory.
NEBIUS_API_KEY=

# Optional. Override this when the model identifier in your Nebius catalog differs.
NEBIUS_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct

# Optional until cloud accounts are enabled. Both values are safe to expose to the browser
# when Row Level Security is enabled using supabase/schema.sql.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional until live OpenEMR integration is enabled. The adapter remains in synthetic mode
# when these are absent. Register Vital Passport as a public SMART app using PKCE.
OPENEMR_BASE_URL=https://your-openemr.example.com/openemr
OPENEMR_SITE=default
OPENEMR_CLIENT_ID=
OPENEMR_REDIRECT_URI=https://vitalpassport.com/openemr/callback
# OPENEMR_SCOPES=openid offline_access api:fhir user/Patient.rs user/DocumentReference.crs user/Observation.crs user/Condition.crs user/AllergyIntolerance.crs user/Provenance.crs
